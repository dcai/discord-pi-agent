DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_ID=
# Optional. Defaults to process.cwd() when using loadDiscordPiBridgeConfigFromEnv()
# PI_AGENT_CWD=
# Optional. Defaults to <cwd>/.pi-agent
# PI_AGENT_DIR=
# Default model is openrouter/anthropic/claude-3.5-haiku
# PI_MODEL_PROVIDER=github-copilot
# PI_MODEL_ID=gpt-5.4
# Optional Discord prompt timestamp formatting. Defaults to UTC / en-AU.
# PI_PROMPT_TIME_ZONE=Australia/Sydney
# PI_PROMPT_LOCALE=en-AU
# Optional startup DM. Set to false to disable.
# DISCORD_STARTUP_MESSAGE=Bot is online and ready.
# Optional one-message second-pass follow-up after each prompt reply.
# DISCORD_REPLY_REFLECTION=true
# Optional proactive follow-up length cap. Defaults to 600.
# DISCORD_REPLY_REFLECTION_MAX_FOLLOW_UP_LENGTH=280

# Audio transcription is enabled by default for voice messages and audio file uploads.
# Set PI_AUDIO_TRANSCRIPTION_ENABLED=false to disable it explicitly.
# Defaults to OpenAI audio transcription API (provider=openai, model=gpt-4o-mini-transcribe).
# For non-openai providers, set PI_AUDIO_TRANSCRIPTION_ENDPOINT explicitly.
# PI_AUDIO_TRANSCRIPTION_ENABLED=false
# PI_AUDIO_TRANSCRIPTION_API_KEY=sk-...
# PI_AUDIO_TRANSCRIPTION_PROVIDER=openai
# PI_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# PI_AUDIO_TRANSCRIPTION_ENDPOINT=https://api.openai.com/v1/audio/transcriptions

# Provider auth env vars depend on the model provider you use.
# Example:
# MOONSHOT_CN_API_KEY=
# COPILOT_GITHUB_TOKEN=
# GH_TOKEN=
# GITHUB_TOKEN=
