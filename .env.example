DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_ID=
# Optional. Defaults to process.cwd() when using loadDiscordPiBridgeConfigFromEnv()
# PI_AGENT_CWD=
# Optional. Defaults to <cwd>/.pi-agent
# PI_AGENT_DIR=
# Default model is openrouter/anthropic/claude-3.5-haiku
# PI_MODEL_PROVIDER=github-copilot
# PI_MODEL_ID=gpt-5.4
# Optional Discord prompt timestamp formatting. Defaults to UTC / en-AU.
# PI_PROMPT_TIME_ZONE=Australia/Sydney
# PI_PROMPT_LOCALE=en-AU
# Feature behavior like startupMessage, replyReflection, and audioTranscription
# mostly belongs in the host app config object, not in this library env file.
# Keep env usage here for boot/runtime essentials and secrets.

# Optional audio transcription secret.
# If audioTranscription.apiKey is omitted in code, the library will use:
# 1. PI_AUDIO_TRANSCRIPTION_API_KEY
# 2. OPENAI_API_KEY fallback
# PI_AUDIO_TRANSCRIPTION_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Provider auth env vars depend on the model provider you use.
# Example:
# MOONSHOT_CN_API_KEY=
# COPILOT_GITHUB_TOKEN=
# GH_TOKEN=
# GITHUB_TOKEN=
