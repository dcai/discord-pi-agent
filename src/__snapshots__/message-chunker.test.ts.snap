exports[`chunkMessage > never splits inside a fenced code block 1`] = `
[
  "Some intro text before the code block.",
  "\`\`\`js
function fibonacci(n) {
  if (n <= 1) return n;
  return fibonacci(n - 1) + fibonacci(n - 2);
}
\`\`\`",
  "Some outro text after the code block.",
]
`;

