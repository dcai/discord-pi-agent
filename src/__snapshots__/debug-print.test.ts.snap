exports[`debugPrint > prints with custom title 1`] = `
[
  [
    "=================================== MY TITLE ===================================",
  ],
  [
    "some body text",
  ],
  [
    "================================= MY TITLE END =================================",
  ],
]
`;

exports[`debugPrint > prints with default DEBUG title 1`] = `
[
  [
    "==================================== DEBUG =====================================",
  ],
  [
    "hello world",
  ],
  [
    "================================== DEBUG END ===================================",
  ],
]
`;
