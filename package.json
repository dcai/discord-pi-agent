{
  "name": "@friendlyrobot/discord-pi-agent",
  "version": "0.31.2",
  "description": "Reusable Discord gateway for persistent pi agent sessions",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcai/discord-pi-agent.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test:watch": "LOG_LEVEL=debug vitest",
    "test": "LOG_LEVEL=silent vitest run",
    "test:coverage": "LOG_LEVEL=silent vitest run --coverage",
    "smoke:task-scheduler": "LOG_LEVEL=silent vitest run --config vitest.smoke.config.ts --reporter=verbose",
    "format": "prettier --write ./src",
    "build:clean": "rm -rf dist",
    "build:emit": "tsgo -p tsconfig.build.json --declaration --declarationMap false",
    "build": "npm run build:clean && npm run build:emit",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "discord.js": "^14.26.5",
    "dotenv": "^17.4.2",
    "jiti": "^2.7.0",
    "marked": "^18.0.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "@google/genai@1.52.0": true,
    "protobufjs@7.6.4": true,
    "protobufjs@7.6.1": true,
    "fsevents@2.3.3": true
  }
}
