{
  "name": "@friendlyrobot/discord-pi-agent",
  "version": "0.4.8",
  "description": "Reusable Discord gateway bridge for persistent pi agent sessions",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcai/discord-pi-agent.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test:watch": "vitest",
    "test": "vitest run",
    "update-deps": "npx npm-check-updates",
    "format": "prettier --write .",
    "build:01-clean": "rm -rf dist",
    "build:02-tsgo": "tsgo -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap false",
    "build:03-build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --packages external",
    "build": "bun run --sequential 'build:*'",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "marked": "^18.0.2",
    "prettier": "^3.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260424.2",
    "@vitest/ui": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
